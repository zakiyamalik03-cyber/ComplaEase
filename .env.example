# =============================================
# Copy this file to .env.local and fill values
# cp .env.example .env.local
# =============================================

# ── NextAuth (REQUIRED) ───────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────
JWT_SECRET=replace_with_a_random_secret_string
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Gemini AI ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_h

# ── Database ──────────────────────────────────
# Default MySQL port is 3306, XAMPP uses 3306
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cms_db
